# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
STREAM_NAME=did-events
GROUP_NAME=did-worker-group
DLQ_SUFFIX=:dlq

# ── Database ───────────────────────────────────────────────────────────────
DB_URL=postgres://postgres:secret@localhost:5432/workerdb?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# ── Blockchain ─────────────────────────────────────────────────────────────
# Comma-separated RPC URLs (hara-core-blockchain-lib NewNetwork)
RPC_URLS=https://rpc1.hara.network,https://rpc2.hara.network

# Hex-encoded ECDSA private key (NewWallet)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Contract resolution — use ONE of the two options below:

# Option A: HNS URI (preferred) — chain.ContractWithHNS(ctx, HNS_NAME)
HNS_NAME=did.registry.hara

# Option B: Direct address + raw JSON ABI — chain.Contract(abi, address)
# CONTRACT_ADDRESS=0xYourContractAddressHere
# CONTRACT_ABI={"abi":[...]}

# ── Worker ─────────────────────────────────────────────────────────────────
CONSUMER_NAME=worker-1
WORKER_CONCURRENCY=10
POLL_INTERVAL=100ms
MAX_RETRY=3
RETRY_BASE_DELAY=1s
SHUTDOWN_TIMEOUT=30s
BATCH_SIZE=10

# ── HTTP server ────────────────────────────────────────────────────────────
SERVER_PORT=8080
